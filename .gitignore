# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/

# User data — machine-specific, never commit
data/settings.json

# Downloaded mods — user's personal library, not source
Mods/

# FModel — 44 MB binary, download separately (see Docs/DevNotes/tools-setup.md)
tools/FModel/
tools/FModel.zip

# Zip/7z archives of tools (binaries are committed directly)
tools/repak.zip

# FModel runtime cache — generated by FModel.exe, not source
Output/

# Claude Code internals — local session state, never source
.claude/

# PyInstaller build artifacts
*.spec

# IDE / editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Windows shortcut files
*.lnk

# Logs generated locally (game logs are in AppData, not here, but just in case)
*.log
